@startuml

/' Config Variables to match OCPP Style '/
skin rose
skinparam shadowing false
hide footbox

/' Enable Teoz renderer for complex nesting '/
!pragma teoz true

/' ISO 15118-20 AC BPT + OCPP 2.1 (Dynamic Control Mode) '/
/' Complete residential V2H (Vehicle-to-Home) bidirectional session: session setup, '/
/' service discovery, PnC auth, BPT charge parameter discovery, schedule exchange, '/
/' power delivery, charge loop (+40A), mid-session direction switch, discharge loop (-40A), '/
/' V2H settlement, session termination '/
/' AC charging omits DC safety phases (CableCheck, PreCharge, WeldingDetection) '/

actor "EV driver" as EVD
participant "ISO 15118-20 EV (EVCC)" as EV
participant "EVSE (SECC)" as CS
participant "OCPP 2.1 CSMS" as CSMS
participant "Secondary Actor (SA)" as SA

/' Explicit participant ordering ensures consistent left-to-right layout '/

group ISO 15118-20 Initialization, Authentication, Authorization
    note over CS, CSMS: All TransactionEventRequest messages carry mandatory\nseqNo, timestamp, and transactionInfo(transactionId)\nper OCPP 2.1 (TransactionEventRequest.json required fields).\nThese envelope fields are omitted here for clarity except\nwhere transactionId is contextually relevant, e.g., the\nperiodic meter value events in the charge/discharge loops.
    SA -> CSMS: Provide Available PmaxSchedule or Tariff Table
    EVD -> EV: Charging Cable Plugged In
    activate CS
    CS -> CSMS: StatusNotificationRequest(connectorStatus: Occupied)
    activate CSMS
    CSMS --> CS: StatusNotificationResponse()
    deactivate CSMS
    CS -> CSMS: TransactionEventRequest(eventType = Started, chargingState = EVConnected, triggerReason = CablePluggedIn,\nidToken(idToken: <emaid-or-placeholder>, type: <IdTokenEnumStringType>,\nadditionalInfo: [{type: "EVCCID", additionalIdToken: <vehicleId>}]))
    activate CSMS
    CSMS --> CS: TransactionEventResponse()
    deactivate CSMS
    deactivate CS

    /' Protocol negotiation and session setup '/
    EV -> CS: SupportedAppProtocolReq()
    activate CS
    CS --> EV: SupportedAppProtocolRes()
    deactivate CS

    EV -> CS: SessionSetupReq()
    activate CS
    CS --> EV: SessionSetupRes()
    deactivate CS

    /' PnC certificate-based authentication inline '/
    EV -> CS: AuthorizationSetupReq()
    activate CS
    CS --> EV: AuthorizationSetupRes(AuthorizationServices: PnC, CertificateInstallationService: false,\nPnC_ASResAuthorizationMode(GenChallenge, SupportedProviders[]))
    deactivate CS

    EV -> CS: AuthorizationReq(SelectedAuthorizationService: PnC,\nPnC_AReqAuthorizationMode(GenChallenge, ContractCertificateChain) [signed])
    activate EV
    activate CS
    loop Until AuthorizeResponse received from CSMS (max 60s (V2G_EVCC_Ongoing_Timeout))
        CS --> EV: AuthorizationRes(EVSEProcessing=Ongoing)
        deactivate CS
        EV -> CS: AuthorizationReq()
        activate CS
    end

    note over CS: Extract eMAID from\nContractCertificate subject field
    CS -> CSMS: AuthorizeRequest(idToken(type = eMAID), iso15118CertificateHashData)
    activate CSMS
    note over CSMS: Validate certificate chain via PKI\nOCSP revocation check: 5-60s latency
    CSMS --> CS: AuthorizeResponse(idTokenInfo(status = Accepted),\nallowedEnergyTransfer: [AC_BPT, AC_single_phase])
    note right: allowedEnergyTransfer is a top-level (2.1)\nfield in AuthorizeResponse. Omitting it\ndefaults to charging only -- must be\npresent for CS to offer BPT services.
    deactivate CSMS

    CS --> EV: AuthorizationRes(EVSEProcessing=Finished, ResponseCode = OK)
    deactivate CS
    deactivate EV

    CS -> CSMS: TransactionEventRequest(eventType = Updated, chargingState = EVConnected, triggerReason = Authorized)
    activate CS
    activate CSMS
    CSMS --> CS: TransactionEventResponse()
    deactivate CS
    deactivate CSMS
end

group Service Discovery and Selection
    /' AC BPT service selection '/
    EV -> CS: ServiceDiscoveryReq()
    activate CS
    CS --> EV: ServiceDiscoveryRes(ServiceRenegotiationSupported: true,\nEnergyTransferServiceList: [AC, AC_BPT])
    deactivate CS

    EV -> CS: ServiceDetailReq(ServiceID: AC_BPT)
    activate CS
    CS --> EV: ServiceDetailRes(ServiceID: AC_BPT,\nServiceParameterList(ParameterSet(ParameterSetID: 1,\nConnector: SinglePhase, ControlMode: Dynamic,\nEVSENominalVoltage: 240, MobilityNeedsMode: EVCC,\nPricing: AbsolutePricing, BPTChannel: Unified,\nGeneratorMode: GridFollowing,\nGridCodeIslandingDetectionMethod: PassiveDetection)))
    note right: ServiceDetailRes parameters per ISO 15118-20\nTable 206 [V2G20-1361]: Connector, ControlMode,\nEVSENominalVoltage, MobilityNeedsMode, Pricing,\nBPTChannel, GeneratorMode, GridCodeIslandingDetectionMethod.\nEVSENominalVoltage per Table 206 is the line-to-neutral\nvoltage. For US residential 240V split-phase (L1-L2 wiring\nwith no neutral on the EV side), implementations commonly\nreport 240 here so the EV can derive current directly from\nEVMaxPower / 240V; a strict-spec reading would be 120\n(L-N from either leg) with the EV computing 240V line-to-line.\nConnector: SinglePhase matches numberPhases: 1 used in\nthe OCPP charging profile below.\nDepartureTime/TargetSOC/V2X energy bounds\nare carried in AC_ChargeParameterDiscoveryReq\nand ScheduleExchangeReq, NOT here.
    deactivate CS

    EV -> CS: ServiceSelectionReq(SelectedEnergyTransferService(\nServiceID: AC_BPT, ParameterSetID: 1), SelectedVASList[opt])
    activate CS
    CS --> EV: ServiceSelectionRes()
    deactivate CS
end

group BPT Charge Parameter Discovery (Dynamic Mode)
    EV -> CS: AC_ChargeParameterDiscoveryReq(\
BPT_AC_CPDReqEnergyTransferMode(\nEVMaximumChargePower: +9600, EVMinimumChargePower: +1000,\nEVMaximumDischargePower: -9600, EVMinimumDischargePower: -1000))
    activate EV
    activate CS
    note right: BPT_AC_CPDReqEnergyTransferMode mandatory fields\nper ISO 15118-20 Table 165 [V2G20-1456]:\nEVMaximumChargePower, EVMinimumChargePower,\nEVMaximumDischargePower, EVMinimumDischargePower.\nAC has NO current/voltage fields (those are DC-only):\nAC uses Power values (Watts), with EVSENominalVoltage\nfrom ServiceDetailRes for current calculation.\nDischarge values NEGATIVE per [V2G20-1213].\nOptional: _L2/_L3 phase variants for asymmetric 3-phase.

    CS --> EV: AC_ChargeParameterDiscoveryRes(\
BPT_AC_CPDResEnergyTransferMode(\nEVSEMaximumChargePower: 9600, EVSEMinimumChargePower: 1000,\nEVSENominalFrequency: 60,\nEVSEMaximumDischargePower: -9600, EVSEMinimumDischargePower: -1000))
    note right: EVSE-side discharge limits NEGATIVE per [V2G20-1213].\nThe rule applies to all parameters used for\ndischarging the EV battery, on both EV and EVSE sides.
    deactivate CS
    deactivate EV
end

group Schedule Exchange (Dynamic Mode) and CSMS Charging Profile
    EV -> CS: ScheduleExchangeReq(MaximumSupportingPoints,\nDynamic_SEReqControlMode(DepartureTime, EVTargetEnergyRequest,\nEVMaximumEnergyRequest, EVMinimumEnergyRequest,\nEVMaximumV2XEnergyRequest, EVMinimumV2XEnergyRequest))
    activate EV
    activate CS
    note right: Dynamic mode: EV provides operating\nenvelope, not a fixed schedule.\nV2X energy bounds for BPT negotiation.\nPer K19.FR.01, this ScheduleExchangeReq triggers\nthe CSMS-bound NotifyEVChargingNeedsRequest below.

    note over CS: Per Q01.FR.09, a strict implementation first requests\nrequested=AC (ChargingOnly) in NotifyEVChargingNeedsRequest,\nthen renegotiates to AC_BPT after CSMS confirms BPT\nin allowedEnergyTransfer. Diagram shows the\npost-renegotiation request (CSMS already returned\nallowedEnergyTransfer: [AC_BPT, AC_single_phase] in AuthorizeResponse).
    CS -> CSMS: NotifyEVChargingNeedsRequest(evseId, chargingNeeds(\
requestedEnergyTransfer: AC_BPT, availableEnergyTransfer: [AC_BPT, AC_single_phase],\ncontrolMode: DynamicControl, mobilityNeedsMode: EVCC,\nv2xChargingParameters(minChargePower: 1000, maxChargePower: 9600,\nminDischargePower: 1000, maxDischargePower: 9600,\nevTargetEnergyRequest: 50000, evMinEnergyRequest: 10000, evMaxEnergyRequest: 75000,\nevMaxV2XEnergyRequest: 50000, evMinV2XEnergyRequest: 10000),\ndepartureTime))
    activate CSMS
    note right: Per K19.FR.06, NotifyEVChargingNeedsRequest SHALL\ncontain V2XChargingParametersType for ISO 15118-20\n(NOT ACChargingParametersType which is the ISO 15118-2 type).\nv2xChargingParameters power values are non-negative\nmagnitudes per the V2X schema; sign is conveyed by\nthe operationMode/setpoint, not by these limits.
    CSMS --> CS: NotifyEVChargingNeedsResponse(status = Accepted)
    note right: CSMS may also return status=Processing\n(per K19.FR.05, CS does NOT wait; it returns\nScheduleExchangeRes using TxDefaultProfile or\nChargingStationMaxProfile, and K16 renegotiation\nruns later when the SetChargingProfileRequest\narrives) or status=NoChargingProfile if CSMS\nrelies on an existing TxDefaultProfile.
    deactivate CSMS

    note over CSMS: DynamicControl mode with V2H:\n- CSMS controls power direction in real-time\n- Responds to home load changes and solar production\n- Positive setpoint = charge from grid\n- Negative setpoint = discharge to home

    loop Until SetChargingProfileRequest received (CS sends ScheduleExchangeRes EVSEProcessing=Ongoing while waiting; CSMS SHOULD respond within 60s [K19.FR.08])
        CS --> EV: ScheduleExchangeRes(EVSEProcessing=Ongoing)
        deactivate CS
        EV -> CS: ScheduleExchangeReq()
        activate CS
    end

    opt if Tariff is configured for EVSE
        CSMS -> CS: SetDefaultTariffRequest(evseId, tariff)
        activate CSMS
        CS --> CSMS: SetDefaultTariffResponse(status = Accepted)
        deactivate CSMS
    end

    CSMS -> CS: SetChargingProfileRequest(evseId, chargingProfile(\
chargingProfilePurpose: TxProfile, transactionId, chargingProfileKind: Dynamic,\nchargingSchedule[](chargingRateUnit: W, numberPhases: 1,\nchargingSchedulePeriod[](startPeriod: 0, setpoint: 9600,\noperationMode: CentralSetpoint))))
    activate CSMS
    CS --> CSMS: SetChargingProfileResponse(status = Accepted)
    deactivate CSMS
    note over CSMS: Initial charge profile: +9600W (Grid -> EV).\nnumberPhases: 1 for US 240V split-phase.\nCentralSetpoint is the bidirectional mode (ChargingOnly\nhas no setpoint). Per Q03.FR.02, limit/dischargeLimit are\nomitted with CentralSetpoint; V2X.03/V2X.04 capping\napplies only to ExternalSetpoint.

    CS --> EV: ScheduleExchangeRes(EVSEProcessing=Finished,\nDynamic_SEResControlMode(AbsolutePriceSchedule(\nTimeAnchor, priceScheduleID, currency, priceAlgorithm,\npriceRuleStacks(import rate, export rate))))
    note right: AbsolutePriceSchedule preferred for BPT:\nnegative prices represent export earnings (EV -> home).\nPriceLevelSchedule is an alternative for simpler\nimplementations but cannot express bidirectional pricing.\nPer K19.FR.09, the CS returns the optional price schedule\nfrom CSMS to the EV here.
    deactivate CS
    deactivate EV
end

group Charging Phase (Grid -> EV, +9.6kW)
    EV -> CS: PowerDeliveryReq(EVProcessing: Finished,\nChargeProgress: Start, EVPowerProfile)
    activate CS
    note right: EVPowerProfile included per normative [V2G20-1546]\n(schema marks optional -- standard contradiction).\nBPT_ChannelSelection NOT sent here:\nper [V2G20-1065] it is required only when the\nBPT system needs HLC-based channel switching\n(BPTChannel = Separated). For BPTChannel = Unified\n(this diagram), it is optional and omitted.
    CS -> CS: Contactor Closed
    note over CS: AC contactor closes without pre-charge\n(AC voltage grid-synchronized,\nno DC safety phases)
    CS --> EV: PowerDeliveryRes()
    deactivate CS

    CS -> CSMS: TransactionEventRequest(eventType = Updated, chargingState = Charging, triggerReason = ChargingStateChanged)
    activate CS
    activate CSMS
    CSMS --> CS: TransactionEventResponse()
    deactivate CS
    deactivate CSMS

    CS -> CSMS: NotifyEVChargingScheduleRequest(timeBase, evseId,\nchargingSchedule, selectedChargingScheduleId)
    activate CS
    activate CSMS
    note right: Per K19.FR.10, the CS SHALL disregard the EV's\nEVPowerProfile and instead send the CSMS-supplied\nchargingSchedule back to the CSMS, with\nselectedChargingScheduleId set to the Id of the\nchosen schedule. This applies in Dynamic Control Mode\n(K19 scenario step 9).
    CSMS --> CS: NotifyEVChargingScheduleResponse(status: Accepted)
    deactivate CS
    deactivate CSMS

    loop Periodic during charging (250ms (V2G_SECC_Sequence_Timeout = 0.5s))
        EV -> CS: AC_ChargeLoopReq(MeterInfoRequested: false,\nBPT_Dynamic_AC_CLReqControlMode(\nDepartureTime[opt], EVTargetEnergyRequest: 50000,\nEVMaximumEnergyRequest: 75000, EVMinimumEnergyRequest: 10000,\nEVMaximumChargePower: +9600, EVMinimumChargePower: +1000,\nEVPresentActivePower: +9480, EVPresentReactivePower: 0,\nEVMaximumDischargePower: -9600, EVMinimumDischargePower: -1000,\nEVMaximumV2XEnergyRequest[opt]: 50000,\nEVMinimumV2XEnergyRequest[opt]: 10000),\nDisplayParameters[opt](TargetSOC[opt]: 80, PresentSOC[opt]: 35))
        activate EV
        activate CS
        CS --> EV: AC_ChargeLoopRes(BPT_Dynamic_AC_CLResControlMode(\nEVSETargetActivePower: +9600, EVSETargetReactivePower: 0,\nEVSEPresentActivePower: +9480))
        deactivate CS
        deactivate EV
    end
    note right: BPT_Dynamic_AC_CLReqControlMode mandatory fields\n(per ISO 15118-20 Table 167 [V2G20-1768]): both charge\nAND discharge limits sent every loop, regardless\nof current direction. Charge values positive,\ndischarge values negative per [V2G20-1213].\nMeterInfoRequested mandatory at AC_ChargeLoopReq top level.\n+9480W EVPresentActivePower = charging (Grid -> EV).\n250ms cycle (V2G_SECC_Sequence_Timeout = 0.5s, same as DC).

    note over CS, EV: Per [V2G20-1083], the SECC triggers the MeteringConfirmation\nexchange by including MeterInfo in an AC_ChargeLoopRes and\nsetting EVSENotification = MeteringConfirmation. Per [V2G20-1084]\nthe MeteringConfirmationReq/Res below travels on the side stream\n(V2GTP PayloadID 0x8102 MeteringConfirmationPayloadID), separate\nfrom the main ChargeLoop stream.
    EV -> CS: MeteringConfirmationReq(SignedMeteringData [signed])
    activate EV
    activate CS
    CS --> EV: MeteringConfirmationRes()
    deactivate CS
    deactivate EV
    note right: EVCC signs metered energy values\nfor non-repudiation (billing proof)

    CS -> CSMS: TransactionEventRequest(eventType = Updated, triggerReason = MeterValuePeriodic, transactionInfo(transactionId), meterValue[](\nsampledValue[](measurand: Energy.Active.Import.Register,\n  value: 8.5, unitOfMeasure(unit: kWh),\n  signedMeterValue(signedMeterData,\n    encodingMethod: OCMF, publicKey)),\nsampledValue[](measurand: Power.Active.Import,\n  value: 9480, unitOfMeasure(unit: W)),\nsampledValue[](measurand: Power.Active.Setpoint,\n  value: 9600, unitOfMeasure(unit: W)),\nsampledValue[](measurand: Power.Active.Residual,\n  value: -120, unitOfMeasure(unit: W))))
    activate CS
    activate CSMS
    note right of CS: V2X monitoring measurands (2.1):\nPower.Active.Setpoint = setpoint CS applied\nPower.Active.Residual = Import - Setpoint\n(tracks setpoint following accuracy)
    CSMS --> CS: TransactionEventResponse()
    deactivate CS
    deactivate CSMS
end

group Mid-Session Direction Switch and Discharging Phase (EV -> Home, -9.6kW)
    note over CSMS: Home solar production exceeds load:\nCSMS switches EV from charging to V2H discharge

    CSMS -> CS: UpdateDynamicScheduleRequest(chargingProfileId,\nscheduleUpdate(setpoint: -9600))
    activate CSMS
    CS --> CSMS: UpdateDynamicScheduleResponse(status = Accepted)
    deactivate CSMS
    note over CSMS: Discharge at -9600W (-9.6 kW, EV -> Home)\nNegative setpoint = discharge direction

    note over CS, CSMS: OCPP 2.1 ChargingStateEnumType has no "Discharging" value.\nDirection change is implicit via negative setpoint.\nCSMS already knows - it initiated the switch.

    loop Periodic during discharging (250ms (V2G_SECC_Sequence_Timeout = 0.5s))
        EV -> CS: AC_ChargeLoopReq(MeterInfoRequested: false,\nBPT_Dynamic_AC_CLReqControlMode(\nDepartureTime[opt], EVTargetEnergyRequest: 50000,\nEVMaximumEnergyRequest: 75000, EVMinimumEnergyRequest: 10000,\nEVMaximumChargePower: +9600, EVMinimumChargePower: +1000,\nEVPresentActivePower: -9540, EVPresentReactivePower: 0,\nEVMaximumDischargePower: -9600, EVMinimumDischargePower: -1000,\nEVMaximumV2XEnergyRequest[opt]: 50000,\nEVMinimumV2XEnergyRequest[opt]: 10000),\nDisplayParameters[opt](TargetSOC[opt]: 80, PresentSOC[opt]: 62))
        activate EV
        activate CS
        CS --> EV: AC_ChargeLoopRes(BPT_Dynamic_AC_CLResControlMode(\nEVSETargetActivePower: -9600, EVSETargetReactivePower: 0,\nEVSEPresentActivePower: -9540))
        deactivate CS
        deactivate EV
    end
    note right: Same field set as charging loop -- only the\nactual EVPresentActivePower / EVSEPresentActivePower\nsign changes (-9540W = EV -> Home discharge).\nDischarge limits negative per [V2G20-1213].\nDirection is signalled by the OCPP setpoint sign\nand by EVPresentActivePower / EVSEPresentActivePower,\nNOT by which fields are sent.

    note over CS, EV: Per [V2G20-1083], the SECC triggers the MeteringConfirmation\nexchange by including MeterInfo in an AC_ChargeLoopRes and\nsetting EVSENotification = MeteringConfirmation. Per [V2G20-1084]\nthe MeteringConfirmationReq/Res below travels on the side stream\n(V2GTP PayloadID 0x8102 MeteringConfirmationPayloadID), separate\nfrom the main ChargeLoop stream.
    EV -> CS: MeteringConfirmationReq(SignedMeteringData [signed])
    activate EV
    activate CS
    CS --> EV: MeteringConfirmationRes()
    deactivate CS
    deactivate EV

    CS -> CSMS: TransactionEventRequest(eventType = Updated, triggerReason = MeterValuePeriodic, transactionInfo(transactionId), meterValue[](\nsampledValue[](measurand: Energy.Active.Export.Register,\n  value: 5.2, unitOfMeasure(unit: kWh),\n  signedMeterValue(signedMeterData,\n    encodingMethod: OCMF, publicKey)),\nsampledValue[](measurand: Power.Active.Export,\n  value: 9540, unitOfMeasure(unit: W)),\nsampledValue[](measurand: Power.Active.Setpoint,\n  value: -9600, unitOfMeasure(unit: W)),\nsampledValue[](measurand: Power.Active.Residual,\n  value: -60, unitOfMeasure(unit: W))))
    activate CS
    activate CSMS
    note right of CS: Discharge phase: Export ~9.54 kW while\nfollowing -9.6 kW setpoint. Residual per\nOCPP 2.1 = Export + Setpoint when Setpoint<0\n(= 9540 + (-9600) = -60).
    CSMS --> CS: TransactionEventResponse()
    deactivate CS
    deactivate CSMS

    note over CSMS, CS: CSMS can switch direction at any time\nvia UpdateDynamicScheduleRequest (OCPP 2.1 Q04 push)
end

group End Charging, V2H Settlement, and Stop OCPP Transaction
    EV -> CS: PowerDeliveryReq(EVProcessing: Finished,\nChargeProgress: Stop, EVPowerProfile)
    activate CS
    CS -> CS: Contactor Opened
    CS --> EV: PowerDeliveryRes()
    deactivate CS

    CS -> CSMS: TransactionEventRequest(eventType = Updated, chargingState = EVConnected, triggerReason = ChargingStateChanged)
    activate CS
    activate CSMS
    CSMS --> CS: TransactionEventResponse()
    deactivate CS
    deactivate CSMS



    EV -> CS: SessionStopReq(ChargingSession: Terminate)
    activate CS
    CS --> EV: SessionStopRes()
    deactivate CS

    CS -> CSMS: NotifySettlementRequest(pspRef, status: Settled,\nsettlementAmount: -3.40, settlementTime, transactionId[opt])
    activate CS
    activate CSMS
    CSMS --> CS: NotifySettlementResponse()
    deactivate CS
    deactivate CSMS
    note over CSMS: Net V2H settlement: -$3.40 (credit to EV owner)\nDerivation from final meter values below:\n  Import: 12.0 kWh x $0.15/kWh = $1.80 cost\n  Export: 13.0 kWh x $0.40/kWh = $5.20 credit\n  Net: $1.80 - $5.20 = -$3.40

    CS -> CSMS: StatusNotificationRequest(connectorStatus: Available)
    activate CS
    activate CSMS
    CSMS --> CS: StatusNotificationResponse()
    deactivate CS
    deactivate CSMS

    CS -> CSMS: TransactionEventRequest(eventType = Ended, chargingState = Idle, triggerReason = EVDeparted, meterValue[](\nsampledValue[](measurand: Energy.Active.Import.Register, context: Transaction.End,\n  value: 12.0, unitOfMeasure(unit: kWh),\n  signedMeterValue(signedMeterData,\n    encodingMethod: OCMF, publicKey)),\nsampledValue[](measurand: Energy.Active.Export.Register, context: Transaction.End,\n  value: 13.0, unitOfMeasure(unit: kWh),\n  signedMeterValue(signedMeterData,\n    encodingMethod: OCMF, publicKey))))
    note right: Final cumulative readings per OCPP 2.1\nSection J (configured via\nSampledDataCtrlr.TxEndedMeasurands).\nReplaces OCPP 1.6J StopTransaction.req\nmeterStop / transactionData. BPT requires\nboth Import and Export registers for billing.\nValues here >= mid-loop snapshots above\n(8.5 kWh import / 5.2 kWh export were\nintra-session checkpoints, not totals).
    activate CS
    activate CSMS
    CSMS --> CS: TransactionEventResponse()
    deactivate CS
    deactivate CSMS
end

@enduml
